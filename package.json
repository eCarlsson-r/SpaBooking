    "@nuxtjs/html-validator": "^1.8.2",
    "@nuxtjs/i18n": "^10.2.4",
    "@nuxtjs/seo": "^2.2.0",
    "@pinegrow/nuxt-module": "^3.0.69",
    "@pinegrow/nuxtui-plugin": "^3.0.40",
