    "@vee-validate/nuxt": "^4.13.2",
    "@vueuse/core": "^11.3.0",
    "date-fns": "^4.1.0",
    "laravel-echo": "^2.2.7",
    "lite-youtube-embed": "^0.3.3",
    "pinia": "^2.2.2",
    "pusher-js": "^8.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@iconify/json": "^2.2.295",
    "@nuxt/content": "^2.13.4",
    "@nuxt/eslint": "^0.7.5",
